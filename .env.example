# Copy to `.env` and adjust per environment.

# --- API server -------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=4000
PUBLIC_URL=http://localhost:4000

# --- Postgres ---------------------------------------------------------------
# Defaults are intentionally "todos" for backward compatibility with v0.1
# data volumes. Override in your .env if you want different ones, but DO NOT
# change the defaults in docker-compose.yml — see the migration notes in
# the BE README for why.
PGHOST=db
PGPORT=5432
PGUSER=todos
PGPASSWORD=todos
PGDATABASE=todos

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://cache:6379

# --- Auth -------------------------------------------------------------------
# CHANGE in any non-demo environment.
JWT_SECRET=change-me-in-prod-please-please
JWT_TTL_SECONDS=86400

# --- Object storage (MinIO/S3) ----------------------------------------------
S3_ENDPOINT=http://objects:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=polyrepo-uploads
S3_FORCE_PATH_STYLE=true

# --- Mail (MailHog in dev) --------------------------------------------------
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Polyrepo Demo <noreply@polyrepo.local>"
